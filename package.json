{
	"name": "token-snake",
	"version": "0.1.2",
	"description": "🐍 An LLM-themed Snake game for your terminal — eat tokens, dodge hallucinations, grow your context window. Play while your AI agent thinks.",
	"type": "module",
	"bin": {
		"token-snake": "dist/cli.mjs"
	},
	"main": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/cli.ts",
		"start": "node dist/cli.mjs",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"snake",
		"terminal",
		"game",
		"cli",
		"tui",
		"llm",
		"tokens",
		"ai",
		"coding",
		"idle",
		"claude",
		"copilot",
		"agent",
		"mcp",
		"context-window",
		"terminal-game",
		"ascii",
		"waiting",
		"developer-tools"
	],
	"license": "MIT",
	"author": {
		"name": "Vipul Gupta",
		"url": "https://mixster.dev",
		"email": "vipulgupta2048@gmail.com"
	},
	"homepage": "https://github.com/vipulgupta2048/token-snake#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vipulgupta2048/token-snake.git"
	},
	"bugs": {
		"url": "https://github.com/vipulgupta2048/token-snake/issues"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/vipulgupta2048"
	},
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@types/node": "^25.3.5",
		"tsup": "^8.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.4.0"
	}
}
